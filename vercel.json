{
  "rewrites": [
    { "source": "/e/:slug", "destination": "/editorial.html" },
    { "source": "/:slug", "destination": "/api/room?vr=:slug" }
  ],
  "functions": {
    "api/room.js": { "includeFiles": "viewing-room.html" }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://t.diez.gallery; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'self'"
        }
      ]
    }
  ]
}
